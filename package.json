{
  "name": "aqua-circle-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "AquaCircle - 前端應用程式（Web + Mobile）",
  "scripts": {
    "web:dev": "pnpm --filter aqua-circle-web dev",
    "web:build": "pnpm --filter aqua-circle-web build",
    "web:preview": "pnpm --filter aqua-circle-web preview",
    "web:lint": "pnpm --filter aqua-circle-web lint",
    "mobile:start": "pnpm --filter aqua-circle-mobile start",
    "mobile:android": "pnpm --filter aqua-circle-mobile android",
    "mobile:ios": "pnpm --filter aqua-circle-mobile ios",
    "mobile:web": "pnpm --filter aqua-circle-mobile web",
    "mobile:lint": "pnpm --filter aqua-circle-mobile lint",
    "lint": "biome check web mobile packages",
    "lint:fix": "biome check --write web mobile packages",
    "format": "biome format --write web mobile packages"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.14.0",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4"
  }
}
